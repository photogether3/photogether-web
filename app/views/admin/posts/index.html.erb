<% content_for :page_title, "게시물 관리 - 포토게더" %>
<% content_for :meta_description, "Photogether 게시물 관리 시스템 - 게시물 조회, 수정 및 삭제" %>

<div class="flex flex-col gap-4 motion-custom-fade-in-slide-up" data-controller="query">
  <h1 class="text-3xl font-bold">게시물 관리</h1>

  <div class="flex items-center justify-between w-full mt-4">
    <%= render partial: 'shared/query', locals: {
      query_form_id: 'post_query_form',
      query_action: '/admin/posts',
      keyword: {
        placeholder: '게시물 제목 또는 내용',
      },
      order_by_list: [
        { label: '생성일', value: 'created_at' },
        { label: '수정일', value: 'updated_at' },
        { label: '제목', value: 'title' },
      ],
      filter_by_list: [
        { label: '모든 카테고리', value: '' },
        *@categories.map { |c| { label: c.name, value: c.id.to_s } }
      ]
    } %>

    <div class="flex items-center justify-center gap-2">
      <%= render partial: 'shared/item_total', locals: {
        total_count_id: 'post_total',
        content: '총 게시물 수',
        total_count: @posts.total_count,
      } %>

      <%= link_to new_admin_post_path,
                  data: { turbo_frame: 'modal_portal' },
                  class: 'h-12 flex items-center justify-center gap-1 bg-primary text-white rounded-xl px-4' do %>
        <%= heroicon("plus", options: { class: "w-5 h-5 text-white" }) %>
        게시물 생성
      <% end %>
    </div>
  </div>

  <!-- 게시물 목록 -->
  <div id="post-list-container">
    <%= render partial: 'admin/posts/post_list' %>
  </div>
</div>