<%= form_with model: post,
              url: post.persisted? ? admin_post_path(post) : admin_posts_path,
              local: true,
              multipart: true, 
              data: { controller: "post-form" },
              html: { id: "post_form", class: "flex flex-col gap-4 w-full" } do |f| %>
  <% if post.errors.any? %>
    <div class="p-4 mb-4 text-sm text-red-800 border border-red-200 bg-red-50 rounded-xl">
      <div class="mb-1 font-medium">다음 오류로 인해 저장할 수 없습니다:</div>
      <ul class="list-disc list-inside">
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 작성자 선택 -->
  <div class="flex flex-col gap-2">
    <label for="post_user_id" class="text-sm font-medium text-gray-700">작성자</label>
    <%= f.collection_select :user_id,
                  @users,
                  :id,
                  :nickname,
                  { include_blank: "작성자 선택" },
                  { required: true, class: "h-12 border border-gray-300 px-4 rounded-xl w-full bg-white" } %>
    <p class="mt-1 text-xs text-gray-500">작성자를 선택하면 해당 사용자의 '미분류' 컬렉션에 자동으로 추가됩니다.</p>
  </div>

  <!-- 제목 -->
  <div class="flex flex-col gap-2">
    <label for="post_title" class="text-sm font-medium text-gray-700">제목</label>
    <%= f.text_field :title,
                    placeholder: "게시물 제목",
                    required: true,
                    class: "h-12 border border-gray-300 px-4 rounded-xl w-full" %>
  </div>

  <!-- 내용 -->
  <div class="flex flex-col gap-2">
    <label for="post_content" class="text-sm font-medium text-gray-700">내용</label>
    <%= f.text_area :content,
                    placeholder: "게시물 내용",
                    required: true,
                    rows: 2,
                    class: "border border-gray-300 p-4 rounded-xl w-full resize-y" %>
  </div>

  <!-- 이미지 업로드 (단일 이미지) -->
  <div class="flex flex-col gap-2">
    <label class="text-sm font-medium text-gray-700">이미지</label>
    
    <% if post.persisted? && post.image.attached? %>
      <div class="relative w-full max-w-md overflow-hidden border border-gray-200 rounded-lg group">
        <%= image_tag url_for(post.image.variant(resize_to_fill: [480, 320])), class: "w-full h-auto object-cover" %>
        <div class="absolute inset-0 flex items-center justify-center transition-opacity bg-black bg-opacity-50 opacity-0 group-hover:opacity-100">
          <div class="flex gap-2">
            <button type="button" class="p-2 text-red-500 bg-white rounded-full hover:bg-red-50"
                    data-action="click->post-form#removeImage" 
                    data-image-id="<%= post.image.id %>">
              <%= heroicon("trash", options: { class: "w-5 h-5" }) %>
            </button>
          </div>
        </div>
      </div>
    <% end %>

    <div class="flex items-center justify-center w-full">
      <label for="post_image" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed cursor-pointer rounded-xl bg-gray-50 hover:bg-gray-100">
        <div class="flex flex-col items-center justify-center pt-5 pb-6">
          <%= heroicon("photo", options: { class: "w-10 h-10 mb-3 text-gray-400" }) %>
          <p class="mb-2 text-sm font-semibold text-gray-500">클릭하여 업로드</p>
          <p class="text-xs text-gray-500">PNG, JPG, GIF (최대 10MB)</p>
        </div>
        <%= f.file_field :image, class: "hidden", accept: "image/*", data: { action: "change->post-form#previewImage" } %>
      </label>
    </div>

    <div id="image-preview" class="relative hidden w-full max-w-md mt-4">
      <img src="" class="object-cover w-full h-auto border border-gray-200 rounded-lg" />
      <div class="absolute inset-0 flex items-center justify-end p-2">
        <button type="button" class="p-2 text-red-500 bg-white rounded-full hover:bg-red-50" data-action="click->post-form#clearPreview">
          <%= heroicon("trash", options: { class: "w-5 h-5" }) %>
        </button>
      </div>
      <div class="absolute bottom-2 right-2">
        <button type="button" class="flex items-center gap-1 p-2 text-xs text-white bg-blue-500 rounded-full shadow hover:bg-blue-600" 
                data-action="click->post-form#extractTextFromImage">
          <%= heroicon("eye", options: { class: "w-4 h-4" }) %>
          텍스트 인식
        </button>
      </div>
    </div>
  </div>

  <!-- 메타데이터 섹션 -->
  <div id="metadata-section" class="flex flex-col gap-2 mt-4">
    <label class="text-sm font-medium text-gray-700">메타데이터</label>
    <div class="p-4 mb-2 text-sm text-blue-700 rounded-lg bg-blue-50">
      <p>이미지에서 인식된 텍스트가 메타데이터 항목으로 추가됩니다. 각 항목에 대해 공개 여부를 설정하세요.</p>
      <p class="mt-1">URL이 포함된 항목은 자동으로 감지되어 링크로 표시됩니다.</p>
    </div>
    
    <div id="metadata-container" class="space-y-2">
      <% if post.persisted? && @metadata.present? %>
        <% @metadata.each_with_index do |metadata, index| %>
          <div class="p-4 mb-2 border border-gray-200 metadata-item rounded-xl">
            <div class="flex justify-between mb-2">
              <h4 class="font-medium">메타데이터 항목 #<%= index + 1 %></h4>
              <button type="button" class="text-gray-400 hover:text-red-500" data-action="click->post-form#removeMetadataItem">
                <%= heroicon("trash", options: { class: "w-5 h-5" }) %>
              </button>
            </div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
              <div class="flex flex-col gap-1 md:col-span-3">
                <label class="text-xs text-gray-500">내용</label>
                <input type="text" name="post[metadata][][content]" value="<%= metadata.content %>" class="p-2 border border-gray-300 rounded-lg" placeholder="내용 입력" data-action="input->post-form#checkForUrl">
              </div>
              <div class="flex items-center gap-2 md:col-span-2">
                <input type="checkbox" name="post[metadata][][isPublic]" id="metadata_public_<%= index + 1 %>" class="rounded" <%= metadata.is_public ? 'checked' : '' %>>
                <label for="metadata_public_<%= index + 1 %>" class="text-sm">공개</label>
              </div>
              <div class="flex items-center gap-2 md:col-span-1">
                <input type="checkbox" name="post[metadata][][hasLink]" id="metadata_link_<%= index + 1 %>" class="rounded" <%= metadata.has_link ? 'checked' : '' %>>
                <label for="metadata_link_<%= index + 1 %>" class="text-sm">링크 포함</label>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    
    <button type="button" class="self-start h-10 px-4 mt-2 text-sm border border-gray-300 rounded-xl hover:bg-gray-50" data-action="click->post-form#addMetadataItem">
      + 메타데이터 항목 직접 추가
    </button>
  </div>

  <div class="flex justify-end gap-4 mt-4">
    <%= link_to "취소", admin_posts_path, class: "h-12 px-6 flex items-center justify-center border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50" %>
    <%= f.submit (post.new_record? ? "게시물 생성" : "게시물 수정"), class: "h-12 px-6 bg-secondary-40 rounded-xl text-white cursor-pointer hover:bg-secondary-50" %>
  </div>
<% end %>