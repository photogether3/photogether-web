<%= turbo_frame_tag :post_list do %>
  <div class="table-view">
    <div class="w-full overflow-hidden bg-white border border-gray-300 rounded-xl">
      <table class="w-full text-center [&_th,td]:p-2 [&_th]:py-4 table-fixed">
        <thead>
          <tr class="border-b border-gray-300">
            <th class="w-16">번호</th>
            <th class="w-20">썸네일</th>
            <th class="w-60">제목</th>
            <th class="w-32">작성자</th>
            <th class="w-24">카테고리</th>
            <th class="w-16">좋아요</th>
            <th class="w-16">댓글</th>
            <th class="w-40">생성일</th>
            <th class="w-20">설정</th>
          </tr>
        </thead>
        <tbody class="motion-preset-fade">
        <% if @posts.any? %>
          <% @posts.each_with_index do |post, i| %>
            <tr id="<%= "post_#{post.id}" %>" class="border-b border-gray-300">
              <td class="truncate"><%= (@posts.current_page - 1) * @posts.limit_value + i + 1 %></td>
              <td class="flex justify-center">
                <% if post.images.attached? %>
                  <%= image_tag url_for(post.images.first.variant(resize_to_fill: [50, 50])), 
                                class: "w-12 h-12 object-cover rounded-md" %>
                <% else %>
                  <div class="flex items-center justify-center w-12 h-12 bg-gray-200 rounded-md">
                    <%= heroicon("photo", options: { class: "w-6 h-6 text-gray-400" }) %>
                  </div>
                <% end %>
              </td>
              <td class="px-4 text-left truncate" title="<%= post.title %>">
                <%= post.title %>
              </td>
              <td class="truncate" title="<%= post.user.nickname %>">
                <%= post.user.nickname %>
              </td>
              <td class="truncate" title="<%= post.category&.name || '미분류' %>">
                <%= post.category&.name || '미분류' %>
              </td>
              <td class="truncate"><%= post.likes_count || 0 %></td>
              <td class="truncate"><%= post.comments_count || 0 %></td>
              <td class="truncate"><%= post.created_at.strftime("%Y.%m.%d %H:%M") %></td>
              <td>
                <%= render partial: 'shared/dropdown', locals: {
                  title: heroicon("cog-8-tooth", options: { class: "w-5 h-5 text-gray-500" }),
                  items: [
                    link_to('상세 보기', admin_post_path(post), data: { 
                      action: 'click->dropdown#select',
                    }),
                    link_to('수정', edit_admin_post_path(post), data: { 
                      action: 'click->dropdown#select',
                      turbo_frame: 'modal_portal'
                    }),
                    link_to('삭제', admin_post_path(post), data: { 
                      action: 'click->dropdown#select',
                      turbo_frame: 'post_list',
                      turbo_method: :delete,
                      turbo_confirm: "정말 삭제하시겠어요?"
                    }),
                  ],
                } %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="py-6 text-gray-500">게시물 목록이 없습니다.</td>
          </tr>
        <% end %>
        </tbody>
      </table>

      <div class="p-4">
        <%= render partial: 'shared/pagination', locals: {
          total_pages: @posts.total_pages,
          current_page: @posts.current_page
        } %>
      </div>
    </div>
  </div>

  <!-- 그리드 보기 (기본적으로 숨겨져 있음) -->
  <div class="hidden grid-view">
    <% if @posts.any? %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        <% @posts.each do |post| %>
          <div id="grid_post_<%= post.id %>" class="overflow-hidden transition-all bg-white border border-gray-200 shadow-sm rounded-xl hover:shadow-md">
            <div class="relative bg-gray-100 aspect-video">
              <% if post.images.attached? %>
                <%= image_tag url_for(post.images.first.variant(resize_to_fill: [400, 225])), 
                              class: "w-full h-full object-cover" %>
              <% else %>
                <div class="flex items-center justify-center w-full h-full">
                  <%= heroicon("photo", options: { class: "w-12 h-12 text-gray-300" }) %>
                </div>
              <% end %>
              <div class="absolute px-2 py-1 text-xs text-white bg-black bg-opacity-50 rounded-lg bottom-2 right-2">
                <span class="flex items-center gap-1">
                  <%= heroicon("chat-bubble-left", options: { class: "w-3 h-3" }) %>
                  <%= post.comments_count || 0 %>
                </span>
              </div>
            </div>
            <div class="p-4">
              <h3 class="mb-1 font-medium text-gray-900 truncate" title="<%= post.title %>"><%= post.title %></h3>
              <p class="mb-2 text-sm text-gray-500">
                <%= post.user.nickname %> • <%= post.created_at.strftime("%Y.%m.%d") %>
              </p>
              <div class="flex items-center justify-between">
                <span class="px-2 py-1 text-xs bg-gray-100 rounded-md"><%= post.category&.name || '미분류' %></span>
                <div class="flex items-center gap-1 text-sm text-gray-500">
                  <%= heroicon("heart", options: { class: "w-4 h-4" }) %>
                  <span><%= post.likes_count || 0 %></span>
                </div>
              </div>
            </div>
            <div class="flex justify-end px-4 py-2 border-t border-gray-100 bg-gray-50">
              <%= link_to admin_post_path(post), class: "text-xs text-gray-500 hover:text-gray-700" do %>
                상세 보기
                <%= heroicon("arrow-right", options: { class: "w-3 h-3 inline" }) %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      
      <div class="mt-6">
        <%= render partial: 'shared/pagination', locals: {
          total_pages: @posts.total_pages,
          current_page: @posts.current_page
        } %>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-12 bg-white rounded-xl">
        <%= heroicon("photo", options: { class: "w-16 h-16 text-gray-300" }) %>
        <p class="mt-4 text-gray-500">게시물 목록이 없습니다.</p>
      </div>
    <% end %>
  </div>
<% end %>