<%= turbo_frame_tag :post_list do %>
  <% if @posts.any? %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 motion-preset-fade">
      <% @posts.each do |post| %>
        <div id="post_<%= post.id %>" class="relative h-64 overflow-hidden transition-all bg-white border border-gray-200 shadow-sm rounded-xl hover:shadow-md">
          <!-- 이미지 부분 (전체 배경으로 사용) -->
          <div class="absolute inset-0 bg-gray-100">
            <% if post.image.attached? %>
              <% begin %>
                <%= image_tag url_for(post.image), class: "w-full h-full object-cover opacity-70" %>
              <% rescue => e %>
                <div class="flex flex-col items-center justify-center w-full h-full p-2 text-center">
                  <%= heroicon("exclamation-triangle", options: { class: "w-8 h-8 text-yellow-500 mb-1" }) %>
                  <span class="text-xs text-gray-500">이미지를 불러올 수 없습니다</span>
                </div>
              <% end %>
            <% else %>
              <div class="flex items-center justify-center w-full h-full">
                <%= heroicon("photo", options: { class: "w-12 h-12 text-gray-300" }) %>
              </div>
            <% end %>
          </div>
          
          <!-- 컨텐츠 오버레이 -->
          <div class="absolute inset-0 flex flex-col">
            <!-- 카테고리/컬렉션 배지 -->
            <div class="self-start px-2 py-1 m-2 text-xs text-white bg-black bg-opacity-50 rounded-lg">
              <%= post.collection&.category&.name || post.collection&.title || '미분류' %>
            </div>
            
            <!-- 게시물 정보 - 중앙 정렬 -->
            <div class="flex flex-col justify-center flex-grow p-4">
    
            </div>
            
            <!-- 작성자 정보 -->
            <div class="p-3 text-white bg-black bg-opacity-30">
              <p class="text-xs">
                <%= post.user&.nickname || '알 수 없음' %> • <%= post.created_at.strftime("%Y.%m.%d") %>
              </p>
            </div>
          </div>
          
          <!-- 작업 버튼 (우측 상단에 배치) -->
          <div class="absolute z-10 top-2 right-2">
            <%= render partial: 'shared/dropdown', locals: {
              title: heroicon("ellipsis-horizontal", options: { class: "w-5 h-5 bg-white rounded-full p-1 shadow-md" }),
              items: [
                link_to('상세 보기', admin_post_path(post), data: { 
                  action: 'click->dropdown#select',
                }),
                link_to('수정', edit_admin_post_path(post), data: { 
                  action: 'click->dropdown#select',
                }),
                link_to('삭제', admin_post_path(post), data: { 
                  action: 'click->dropdown#select',
                  turbo_method: :delete,
                  turbo_confirm: "정말 삭제하시겠어요?"
                }),
              ],
              options: {
                position: 'right', 
                class: 'z-50 overflow-visible'
              }
            } %>
          </div>
        </div>
      <% end %>
    </div>
    
    <div class="mt-6">
      <%= render partial: 'shared/pagination', locals: {
        total_pages: @posts.total_pages,
        current_page: @posts.current_page
      } %>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center py-12 bg-white rounded-xl">
      <%= heroicon("photo", options: { class: "w-16 h-16 text-gray-300" }) %>
      <p class="mt-4 text-gray-500">게시물 목록이 없습니다.</p>
    </div>
  <% end %>
<% end %>