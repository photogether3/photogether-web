<% content_for :page_title, "카테고리관리 - 포토게더" %>
<% content_for :meta_description, "Photogether 관리자 대시보드 - 사용자, 카테고리, 게시물 통계 및 시스템 정보 확인" %>

<div class="flex flex-col gap-4 motion-custom-fade-in-slide-up" data-controller="query">
  <h1 class="text-3xl font-bold">카테고리 관리</h1>

  <div class="flex items-center justify-between w-full mt-4">
    <%= render partial: 'shared/query', locals: {
      query_form_id: 'category_query_form',
      query_action: '/admin/categories',
      keyword: {
        placeholder: '카테고리명',
      },
      order_by_list: [
        { label: '생성일', value: 'created_at' },
        { label: '카테고리명', value: 'name' },
      ]
    } %>

    <div class="flex items-center justify-center gap-2">
      <%= render partial: 'shared/item_total', locals: {
        total_count_id: 'category_total',
        content: '총 카테고리 수',
        total_count: @categories.total_count,
      } %>

      <%= link_to new_admin_category_path,
                  data: { turbo_frame: 'modal_portal' },
                  class: 'h-12 flex items-center justify-center gap-1 bg-primary text-white rounded-xl px-4' do %>
        <%= heroicon("plus", options: { class: "w-5 h-5 text-white" }) %>
        카테고리 생성
      <% end %>
    </div>
  </div>

  <%= render partial: 'admin/categories/category_list' %>
</div>
