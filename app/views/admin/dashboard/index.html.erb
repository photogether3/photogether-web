<% content_for :page_title, "관리자 대시보드 - 포토게더" %>
<% content_for :meta_description, "Photogether 관리자 대시보드 - 사용자, 카테고리, 게시물 통계 및 시스템 정보 확인" %>

<div class="flex flex-col gap-6 motion-custom-fade-in-slide-up">
  <h1 class="text-3xl font-bold">관리자 대시보드</h1>
  
  <!-- 요약 통계 카드 영역 -->
  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    <!-- 사용자 통계 카드 -->
    <div class="flex flex-col p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">회원 현황</h2>
        <div class="p-2 rounded-full bg-blue-50">
          <%= heroicon("user", options: { class: "w-6 h-6 text-blue-500" }) %>
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-3xl font-bold"><%= User.count rescue 0 %></span>
        <span class="text-sm text-gray-500">총 회원 수</span>
      </div>
      <div class="pt-4 mt-4 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500">최근 가입</span>
          <span class="text-sm font-medium"><%= User.order(created_at: :desc).first&.created_at&.strftime("%Y.%m.%d") rescue '데이터 없음' %></span>
        </div>
      </div>
      <div class="mt-6">
        <%= link_to admin_users_path, class: "w-full px-4 py-2 text-sm text-center text-blue-600 border border-blue-200 rounded-lg hover:bg-blue-50 transition" do %>
          회원 관리로 이동 <%= heroicon("arrow-right", options: { class: "inline-block w-4 h-4 ml-1" }) %>
        <% end %>
      </div>
    </div>
    
    <!-- 카테고리 통계 카드 -->
    <div class="flex flex-col p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">카테고리 현황</h2>
        <div class="p-2 rounded-full bg-amber-50">
          <%= heroicon("tag", options: { class: "w-6 h-6 text-amber-500" }) %>
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-3xl font-bold"><%= Category.count rescue 0 %></span>
        <span class="text-sm text-gray-500">총 카테고리 수</span>
      </div>
      <div class="pt-4 mt-4 border-t border-gray-200">
        <div class="flex flex-col gap-2">
          <span class="text-sm text-gray-500">인기 카테고리 (즐겨찾기 기준)</span>
          <% top_categories = Category.left_joins(:favorites).group(:id).order('COUNT(favorites.id) DESC').limit(2) rescue [] %>
          <% if top_categories.any? %>
            <% top_categories.each do |category| %>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium"><%= category.name %></span>
                <span class="text-xs bg-amber-100 text-amber-800 px-2 py-0.5 rounded-full"><%= category.favorites.count rescue 0 %> 즐겨찾기</span>
              </div>
            <% end %>
          <% else %>
            <span class="text-sm italic text-gray-400">데이터 없음</span>
          <% end %>
        </div>
      </div>
      <div class="mt-6">
        <%= link_to admin_categories_path, class: "w-full px-4 py-2 text-sm text-center text-amber-600 border border-amber-200 rounded-lg hover:bg-amber-50 transition" do %>
          카테고리 관리로 이동 <%= heroicon("arrow-right", options: { class: "inline-block w-4 h-4 ml-1" }) %>
        <% end %>
      </div>
    </div>
    
    <!-- 게시물 통계 카드 -->
    <div class="flex flex-col p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">게시물 현황</h2>
        <div class="p-2 rounded-full bg-emerald-50">
          <%= heroicon("photo", options: { class: "w-6 h-6 text-emerald-500" }) %>
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-3xl font-bold"><%= Post.count rescue 0 %></span>
        <span class="text-sm text-gray-500">총 게시물 수</span>
      </div>
      <div class="pt-4 mt-4 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500">최근 30일 게시물</span>
          <span class="text-sm font-medium"><%= Post.where('created_at >= ?', 30.days.ago).count rescue 0 %> 개</span>
        </div>
        <div class="flex items-center justify-between mt-2">
          <span class="text-sm text-gray-500">사용자당 평균</span>
          <span class="text-sm font-medium">
            <% avg = User.count > 0 ? (Post.count.to_f / User.count).round(1) : 0 rescue 0 %>
            <%= avg %> 개
          </span>
        </div>
      </div>
      <div class="mt-6">
        <%= link_to "#", class: "w-full px-4 py-2 text-sm text-center text-emerald-600 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition" do %>
          게시물 관리로 이동 <%= heroicon("arrow-right", options: { class: "inline-block w-4 h-4 ml-1" }) %>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- 중간 영역: API 문서 링크 및 최근 활동 -->
  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    <!-- API 문서 링크 -->
    <div class="p-6 text-white border border-gray-300 shadow-md md:col-span-1 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold">API 문서</h2>
        <%= heroicon("code-bracket", options: { class: "w-8 h-8 text-white opacity-80" }) %>
      </div>
      <p class="mb-6 text-white/80">RESTful API 스펙 문서를 확인하여 개발에 참고하세요.</p>
      <%= link_to '/admin/docs', target: "_blank", class: "inline-flex items-center justify-center w-full px-4 py-3 bg-white text-indigo-600 font-medium rounded-lg hover:bg-opacity-90 transition shadow-sm" do %>
        <%= heroicon("document-text", options: { class: "w-5 h-5 mr-2" }) %> 
        API 문서 열기
      <% end %>
    </div>
    
    <!-- 최근 가입 회원 -->
    <div class="p-6 bg-white border border-gray-300 shadow-sm md:col-span-2 rounded-xl">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">최근 가입 회원</h2>
        <%= link_to admin_users_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
          모두 보기
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-2 py-3 font-medium text-left text-gray-500">닉네임</th>
              <th class="px-2 py-3 font-medium text-left text-gray-500">이메일</th>
              <th class="px-2 py-3 font-medium text-left text-gray-500">가입일</th>
            </tr>
          </thead>
          <tbody>
            <% recent_users = User.order(created_at: :desc).limit(5) rescue [] %>
            <% if recent_users.any? %>
              <% recent_users.each do |user| %>
                <tr class="border-b border-gray-100 hover:bg-gray-50">
                  <td class="px-2 py-3"><%= user.nickname %></td>
                  <td class="px-2 py-3"><%= user.email_address %></td>
                  <td class="px-2 py-3"><%= user.created_at.strftime("%Y.%m.%d %H:%M") %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="py-4 text-center text-gray-500">최근 가입한 회원이 없습니다.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  
  <!-- 하단 영역: 시스템 정보 -->
  <div class="p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-700">시스템 정보</h2>
      <div class="p-2 bg-gray-100 rounded-full">
        <%= heroicon("server", options: { class: "w-5 h-5 text-gray-500" }) %>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      <div class="p-4 rounded-lg bg-gray-50">
        <div class="mb-1 text-sm text-gray-500">Ruby 버전</div>
        <div class="font-medium"><%= RUBY_VERSION %></div>
      </div>
      <div class="p-4 rounded-lg bg-gray-50">
        <div class="mb-1 text-sm text-gray-500">Rails 버전</div>
        <div class="font-medium"><%= Rails.version %></div>
      </div>
      <div class="p-4 rounded-lg bg-gray-50">
        <div class="mb-1 text-sm text-gray-500">환경</div>
        <div class="font-medium"><%= Rails.env.capitalize %></div>
      </div>
    </div>
  </div>
</div>