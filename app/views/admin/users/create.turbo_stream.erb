<% if @user.errors.none? %>
  <turbo-stream action="replace" target="user_list">
    <template>
      <script>
        window.Turbo.visit('/admin/users');
      </script>
    </template>
  </turbo-stream>
<% else %>
  <turbo-stream action="replace" target="modal">
    <template>
      <%= render layout: 'shared/modal', formats: [:html] do %>
        <%= render partial: 'admin/users/form', formats: [:html], locals: { user: @user } %>
      <% end %>
    </template>
  </turbo-stream>
<% end %>
