<div class="flex flex-col gap-4" data-controller="query">
  <h1 class="text-3xl font-bold">회원 관리</h1>

  <div class="flex items-center justify-between w-full mt-4">
    <%= render partial: 'admin/users/query', locals: {
      order_by_list: [
        { label: '생성일', value: 'created_at' },
        { label: '닉네임', value: 'nickname' },
        { label: '이메일', value: 'email_address' },
      ]
    } %>

    <div class="flex items-center justify-center gap-2">
      <div class="flex items-center border-2 border-primary rounded-xl h-12 px-4 shadow-lg shadow-secondary/50 gap-2">
        <span class="text-sm text-gray-500">총 회원 수</span>
        <span class="text-lg font-bold text-primary"><%= @users.total_count rescue User.count %></span>
      </div>

      <%= link_to new_admin_user_path,
                  data: { turbo_frame: 'modal_portal' },
                  class: 'h-12 flex items-center justify-center gap-1 bg-primary text-white rounded-xl px-4 py-2 shadow-lg shadow-primary/50' do %>
        <%= heroicon("plus", options: { class: "w-5 h-5 text-white" }) %>
        회원 생성
      <% end %>
    </div>
  </div>

  <%= render partial: 'admin/users/user_list' %>
</div>
