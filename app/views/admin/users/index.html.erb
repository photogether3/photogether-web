

<div class="flex flex-col gap-4 max-w-5xl" data-controller="query">
  <div class="flex justify-between items-center w-full">
    <h1 class="text-2xl">회원 관리</h1>
    <%= link_to '회원 생성', new_admin_user_path, data: { turbo_frame: 'modal_portal' }, class: 'bg-primary text-white rounded-lg p-2' %>
  </div>

  <%= render partial: 'admin/users/query', locals: {
    order_by_list: [
      { label: '생성일', value: 'created_at' },
      { label: '닉네임', value: 'nickname' },
      { label: '이메일', value: 'email_address' },
    ]
  } %>
  <%= render partial: 'admin/users/user_list' %>
</div>
