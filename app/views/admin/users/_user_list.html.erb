<%= turbo_frame_tag :user_list do %>
  <div class="w-full overflow-hidden bg-white border border-gray-300 rounded-xl">
    <table class="w-full text-center [&_th,td]:p-2 [&_th]:py-4 table-fixed">
      <thead>
      <tr class="border-b border-gray-300">
        <th class="w-16">번호</th>
        <th class="w-32">닉네임</th>
        <th class="w-60">이메일</th>
        <th class="w-24">이메일 인증</th>
        <th class="w-24">역할</th>
        <th class="w-40">생성일</th>
        <th class="w-20">설정</th>
      </tr>
      </thead>
      <tbody class="motion-preset-fade">
      <% if @users.any? %>
        <% @users.each_with_index do |user, i| %>
          <tr id="<%= "user_#{user.id}" %>" class="border-b border-gray-300">
            <td class="truncate"><%= (@users.current_page - 1) * @users.limit_value + i + 1 %></td>
            <td class="truncate" title="<%= user.nickname %>"><%= user.nickname %></td>
            <td class="truncate" title="<%= user.email_address %>"><%= user.email_address %></td>
            <td class="truncate"><%= user.is_email_verified %></td>
            <td class="truncate"><%= user.role_id == 1 ? '회원' : '관리자' %></td>
            <td class="truncate"><%= user.created_at.strftime("%Y.%m.%d %H:%M") %></td>
            <td>
              <%= render partial: 'shared/dropdown', locals: {
                title: heroicon("cog-8-tooth", options: { class: "w-5 h-5 text-gray-500" }),
                items: [
                  link_to('수정', edit_admin_user_url(user), data: { 
                    action: 'click->dropdown#select',
                    turbo_frame: 'modal_portal'
                  }),
                  link_to('삭제', admin_user_url(user), data: { 
                    action: 'click->dropdown#select',
                    turbo_frame: 'user_list',
                    turbo_method: :delete,
                    turbo_confirm: "정말 삭제하시겠어요?"
                  }),
                ],
              } %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="7" class="py-6 text-gray-500">회원 목록이 없습니다.</td>
        </tr>
      <% end %>
      </tbody>
    </table>

    <div class="p-4">
      <%= render partial: 'shared/pagination', locals: {
        total_pages: @users.total_pages,
        current_page: @users.current_page
      } %>
    </div>
  </div>
<% end %>