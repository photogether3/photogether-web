<% content_for :page_title, "로그 현황 - 포토게더" %>
<% content_for :meta_description, "Photogether 로그 현황 - 시스템 로그 조회 및 모니터링" %>

<div class="flex flex-col gap-4 motion-custom-fade-in-slide-up" data-controller="log">
  <h1 class="text-3xl font-bold">로그 현황</h1>

  <div class="flex flex-col gap-6">
    <!-- 상단 통계 및 필터 영역 -->
    <div class="p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <!-- 로그 타입 선택 -->
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <%= heroicon("document-text", options: { class: "w-5 h-5 text-gray-500" }) %>
            <span class="font-medium text-gray-700">로그 파일:</span>
          </div>
          <%= form_with url: admin_logs_path, method: :get, data: { turbo_frame: '_top' }, class: "flex" do |f| %>
            <%= f.select :log_type, 
                options_for_select(@log_types, @current_log), 
                {}, 
                class: "px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
            <%= f.hidden_field :lines, value: @lines_count %>
            <%= f.hidden_field :log_level, value: @log_level %>
            <%= f.hidden_field :query, value: @search_query %>
            <%= f.submit "변경", class: "ml-2 px-4 py-2 bg-secondary-40 text-white rounded-lg hover:bg-secondary-50 transition" %>
          <% end %>
        </div>

        <!-- 로그 레벨 필터 -->
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <%= heroicon("funnel", options: { class: "w-5 h-5 text-gray-500" }) %>
            <span class="font-medium text-gray-700">로그 레벨:</span>
          </div>
          <%= form_with url: admin_logs_path, method: :get, data: { turbo_frame: '_top' }, class: "flex" do |f| %>
            <%= f.hidden_field :log_type, value: @current_log %>
            <%= f.hidden_field :lines, value: @lines_count %>
            <%= f.hidden_field :query, value: @search_query %>
            <%= f.select :log_level, 
                options_for_select([
                  ["모든 로그", "all"],
                  ["정보 (INFO)", "info"],
                  ["경고 (WARNING)", "warning"],
                  ["오류 (ERROR)", "error"],
                  ["디버그 (DEBUG)", "debug"]
                ], @log_level || "all"), 
                {}, 
                class: "px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
            <%= f.submit "필터", class: "ml-2 px-4 py-2 bg-secondary-40 text-white rounded-lg hover:bg-secondary-50 transition" %>
          <% end %>
        </div>

        <!-- 로그 라인 수 설정 -->
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <%= heroicon("list-bullet", options: { class: "w-5 h-5 text-gray-500" }) %>
            <span class="font-medium text-gray-700">로드할 줄 수:</span>
          </div>
          <%= form_with url: admin_logs_path, method: :get, data: { turbo_frame: '_top' }, class: "flex" do |f| %>
            <%= f.hidden_field :log_type, value: @current_log %>
            <%= f.hidden_field :log_level, value: @log_level %>
            <%= f.hidden_field :query, value: @search_query %>
            <%= f.select :lines, 
                options_for_select([
                  ["100줄", "100"],
                  ["500줄", "500"],
                  ["1000줄", "1000"],
                  ["5000줄", "5000"]
                ], @lines_count), 
                {}, 
                class: "px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
            <%= f.submit "변경", class: "ml-2 px-4 py-2 bg-secondary-40 text-white rounded-lg hover:bg-secondary-50 transition" %>
          <% end %>
        </div>
      </div>

      <!-- 검색 -->
      <div class="pt-4 mt-6 border-t border-gray-200">
        <%= form_with url: admin_logs_path, method: :get, data: { turbo_frame: '_top' }, class: "flex w-full" do |f| %>
          <%= f.hidden_field :log_type, value: @current_log %>
          <%= f.hidden_field :lines, value: @lines_count %>
          <%= f.hidden_field :log_level, value: @log_level %>
          <div class="relative flex-grow">
            <%= f.text_field :query, 
                value: @search_query,
                placeholder: "로그 내용 검색...", 
                class: "w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <%= heroicon("magnifying-glass", options: { class: "w-5 h-5 text-gray-400" }) %>
            </div>
          </div>
          <%= f.submit "검색", class: "ml-2 px-6 py-2 bg-secondary-40 text-white rounded-lg hover:bg-secondary-50 transition" %>
          <% if @search_query.present? %>
            <%= link_to "초기화", admin_logs_path(log_type: @current_log, lines: @lines_count, log_level: @log_level), 
                class: "ml-2 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 로그 내용 표시 영역 -->
    <div class="bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-700">로그 내용</h2>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500" id="log-count"><%= @log_entries.length %> 개의 로그 항목</span>
          <button class="p-1.5 rounded hover:bg-gray-100" id="refresh-logs" data-action="log#refreshLogs">
            <%= heroicon("arrow-path", options: { class: "w-5 h-5 text-gray-500" }) %>
          </button>
        </div>
      </div>
      
      <div class="p-4 max-h-[600px] overflow-y-auto font-mono text-sm bg.white" data-log-target="logContainer">
        <%= turbo_frame_tag "log_entries" do %>
          <%= render partial: "admin/logs/log_entries", locals: { log_entries: @log_entries } %>
        <% end %>
      </div>
      
      <% if @log_entries.length == 0 && @search_query.present? %>
        <div class="p-4 text-center text-gray-500 border-t border-gray-200">
          검색 결과가 없습니다. 다른 검색어를 시도해보세요.
          <%= link_to "모든 로그 보기", admin_logs_path(log_type: @current_log, lines: @lines_count, log_level: @log_level), 
              class: "text-secondary-40 hover:underline ml-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>