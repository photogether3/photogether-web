<% content_for :page_title, "로그 현황 - 포토게더" %>
<% content_for :meta_description, "Photogether 로그 현황 - 시스템 로그 조회 및 모니터링" %>

<div class="flex flex-col gap-4 motion-custom-fade-in-slide-up" data-controller="log">
  <h1 class="text-3xl font-bold">로그 현황</h1>

  <div class="flex flex-col gap-6">
    <!-- 통합된 필터 영역 -->
    <div class="p-6 bg-white border border-gray-300 shadow-sm rounded-xl">
      <%= form_with url: admin_logs_path, method: :get, data: { turbo_frame: '_top' }, class: "flex flex-col gap-5" do |f| %>
        <!-- 필터 옵션 그리드 (2x2) -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <!-- 1행 1열: 로그 환경 선택 -->
          <div class="flex items-center gap-2">
            <div class="flex items-center w-24 gap-2">
              <%= heroicon("server", options: { class: "w-5 h-5 text-gray-500" }) %>
              <span class="font-medium text-gray-700">환경:</span>
            </div>
            <%= f.select :env, 
                options_for_select(@environments, @current_env), 
                {}, 
                class: "flex-grow px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
          </div>
          
          <!-- 1행 2열: 로그 레벨 필터 -->
          <div class="flex items-center gap-2">
            <div class="flex items-center w-24 gap-2">
              <%= heroicon("funnel", options: { class: "w-5 h-5 text-gray-500" }) %>
              <span class="font-medium text-gray-700">로그 레벨:</span>
            </div>
            <%= f.select :log_level, 
                options_for_select([
                  ["모든 로그", "all"],
                  ["정보 (INFO)", "info"],
                  ["경고 (WARNING)", "warning"],
                  ["오류 (ERROR)", "error"],
                  ["디버그 (DEBUG)", "debug"]
                ], @log_level || "all"), 
                {}, 
                class: "flex-grow px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
          </div>
          
          <!-- 2행 1열: 날짜 선택 -->
          <div class="flex items-center gap-2">
            <div class="flex items-center w-24 gap-2">
              <%= heroicon("calendar", options: { class: "w-5 h-5 text-gray-500" }) %>
              <span class="font-medium text-gray-700">날짜:</span>
            </div>
            <%= f.date_field :date, 
                value: @current_date,
                class: "flex-grow px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
          </div>
          
          <!-- 2행 2열: 시간대 선택 -->
          <div class="flex items-center gap-2">
            <div class="flex items-center w-24 gap-2">
              <%= heroicon("clock", options: { class: "w-5 h-5 text-gray-500" }) %>
              <span class="font-medium text-gray-700">시간대:</span>
            </div>
            <%= f.select :time_range, 
                options_for_select(@time_ranges.map { |range| 
                  start_hour, end_hour = range.split('-').map(&:to_i)
                  ["#{start_hour}시 ~ #{end_hour}시", range] 
                }, @current_time_range),
                {}, 
                class: "flex-grow px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
          </div>
          
          <!-- API 로그만 고정 (hidden 필드로 전달) -->
          <%= f.hidden_field :api_only, value: "true" %>
        </div>

        <!-- 검색 영역 -->
        <div class="pt-4 border-t border-gray-200">
          <div class="flex items-start">
            <div class="relative flex-grow">
              <%= f.text_field :query, 
                  value: @search_query,
                  placeholder: "로그 내용 검색...", 
                  class: "w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-1 focus:ring-secondary-40 focus:border-secondary-40" %>
              <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                <%= heroicon("magnifying-glass", options: { class: "w-5 h-5 text-gray-400" }) %>
              </div>
            </div>
            
            <div class="flex ml-2">
              <%= f.submit "로그 검색", class: "px-6 py-2 bg-secondary-40 text-white font-medium rounded-lg hover:bg-secondary-50 transition" %>
              
              <% if @search_query.present? || @log_level != "all" %>
                <%= link_to "필터 초기화", admin_logs_path(
                    env: @current_env, 
                    date: @current_date,
                    time_range: @current_time_range,
                    api_only: true
                  ), 
                  class: "ml-2 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 로그 내용 표시 영역 -->
    <div class="bg-white border border-gray-300 shadow-sm rounded-xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-700">
          API 로그 - <%= @current_env.capitalize %> (<%= @current_date %>, <%= @current_time_range.split('-').first %>시~<%= @current_time_range.split('-').last %>시)
        </h2>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500" id="log-count"><%= @log_entries.length %> 개의 로그 항목</span>
          <button class="p-1.5 rounded hover:bg-gray-100" id="refresh-logs" data-action="log#refreshLogs">
            <%= heroicon("arrow-path", options: { class: "w-5 h-5 text-gray-500" }) %>
          </button>
        </div>
      </div>
      
      <div class="p-4 overflow-y-auto font-mono text-sm bg-white" data-log-target="logContainer">
        <%= turbo_frame_tag "log_entries" do %>
          <%= render partial: "admin/logs/log_entries", locals: { log_entries: @log_entries } %>
        <% end %>
      </div>
      
      <% if @log_entries.empty? %>
        <div class="p-4 text-center text-gray-500 border-t border-gray-200">
          <% if @search_query.present? %>
            검색 결과가 없습니다. 다른 검색어를 시도해보세요.
            <%= link_to "모든 로그 보기", admin_logs_path(
                env: @current_env, 
                date: @current_date,
                time_range: @current_time_range,
                log_level: "all",
                api_only: true
              ), 
              class: "text-secondary-40 hover:underline ml-2" %>
          <% else %>
            선택한 시간대에 로그가 없습니다. 다른 시간대를 선택해보세요.
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>