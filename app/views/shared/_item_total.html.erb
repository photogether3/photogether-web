<%
# total_count_id: required
# total_count: required
%>
<%= turbo_frame_tag total_count_id do %>
  <div class="flex items-center h-12 gap-2 px-4 bg-white border-2 border-primary rounded-xl">
    <span class="text-sm text-gray-500">
      <% if local_assigns[:content] %>
        <%= content %>
      <% end %>
    </span>
    <span class="text-lg font-bold text-primary">
      <% if local_assigns[:total_count] %>
        <%= total_count %>
      <% end %>
    </span>
  </div>
<% end %>