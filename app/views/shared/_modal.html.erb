<% modal_anims = @modal_anims ||= 'motion-preset-fade' %>
<div
  id="modal"
  data-controller="modal"
  data-modal-refresh-url-value="<%= local_assigns[:refresh_url] %>"
  data-action="turbo:submit-end->modal#submit"
  class="fixed inset-0 bg-black/50 flex justify-center items-center z-50 <%= modal_anims %>">
  <div class="w-full max-w-lg p-4 mx-4 bg-white rounded-lg sm:h-auto">
    <div class="flex items-center justify-between w-full">
      <div class="text-xl font-bold"><%= title ||= '' %></div>
      <button 
        data-action="click->modal#close" 
        class="cursor-pointer">
        <%= heroicon('x-mark', options: { class: "w-6 h-6 text-gray-600" }) %>
      </button>
    </div>
    <div class="mt-4">
      <%= yield %>
    </div>
  </div>
</div>