<div class="max-w-4xl min-h-screen px-4 mx-auto my-8">
  <div class="overflow-hidden bg-white border border-gray-200 rounded-lg">
    <div class="p-6 border-b border-gray-200">
      <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center">
        <h1 class="text-2xl font-bold text-gray-800"><%= @policy.title %></h1>
        <span class="inline-block px-3 py-1 text-sm font-medium text-blue-800 bg-blue-100 rounded-full">버전 <%= @policy.version %></span>
      </div>
      <p class="mt-2 text-sm text-gray-500">발효일: <%= @policy.effective_date.strftime('%Y년 %m월 %d일') %></p>
    </div>
    
    <div class="p-6">
      <div class="prose max-w-none">
        <%= sanitize @policy.content, tags: %w(h1 h2 h3 h4 h5 h6 p strong em u s ul ol li a blockquote br div span), attributes: %w(href class id style) %>
      </div>
    </div>
  </div>
  
  <div class="mt-6 text-center">
    <%= link_to "홈으로 돌아가기", root_path, 
        class: "inline-block px-5 py-2.5 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300 transition-colors" %>
  </div>
</div>