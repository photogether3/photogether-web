<!DOCTYPE html>
<html lang="ko" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if content_for?(:page_title) %>
    <title><%= yield :page_title %></title>
  <% else %>
    <title>포토게더 관리</title>
  <% end %>

  <% if content_for?(:meta_description) %>
    <meta name="description" content="<%= yield :meta_description %>">
  <% else %>
    <meta name="description" content="Photogether 관리자 대시보드">
  <% end %>

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
</head>
<body class="bg-gray-100">
  <div class="flex min-h-screen">
    <!-- 왼쪽 사이드바 - sticky -->
    <aside class="sticky top-0 flex flex-col h-screen p-2 bg-white border-r border-gray-300 w-60 min-w-60">
      <div class="flex justify-center p-4">
        <a href="#" class="-m-1.5 p-1.5">
          <span class="sr-only">Photogether</span>
          <%= image_tag "photogether-logo.png", alt: "Photogether Logo", class: "h-12 w-auto" %>
        </a>
      </div>
      
      <!-- 메뉴 항목들 -->
      <ul class="flex flex-col gap-2 mt-4">
        <li>
          <%= link_to admin_root_path, 
              class: "flex items-center px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors
                      #{current_page?(admin_root_path) ? 'bg-secondary-40 text-white hover:bg-secondary-50 motion-preset-bounce' : 'text-gray-700'}" do %>
            <%= heroicon("home", 
                options: { class: "w-5 h-5 mr-3
                          #{current_page?(admin_root_path) ? 'text-white' : 'text-gray-500'}" }) %>
            <span>대시보드</span>
          <% end %>
        </li>

        <li>
          <%= link_to admin_users_path, 
              class: "flex items-center px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors
                      #{current_page?(admin_users_path) ? 'bg-secondary-40 text-white hover:bg-secondary-50 motion-preset-bounce' : 'text-gray-700'}" do %>
            <%= heroicon("user-group", 
                options: { class: "w-5 h-5 mr-3
                          #{current_page?(admin_users_path) ? 'text-white' : 'text-gray-500'}" }) %>
            <span>회원 관리</span>
          <% end %>
        </li>

        <li>
          <%= link_to admin_categories_path, 
              class: "flex items-center px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors
                      #{current_page?(admin_categories_path) ? 'bg-secondary-40 text-white hover:bg-secondary-50 motion-preset-bounce' : 'text-gray-700'}" do %>
            <%= heroicon("folder", 
                options: { class: "w-5 h-5 mr-3
                          #{current_page?(admin_categories_path) ? 'text-white' : 'text-gray-500'}" }) %>
            <span>카테고리 관리</span>
          <% end %>
        </li>

        <li>
          <%= link_to admin_posts_path, 
              class: "flex items-center px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors text-gray-700
              #{current_page?(admin_posts_path) ? 'bg-secondary-40 text-white hover:bg-secondary-50 motion-preset-bounce' : 'text-gray-700'}" do %>
            <%= heroicon("photo", 
              options: { class: "w-5 h-5 mr-3 text-gray-500
                        #{current_page?(admin_posts_path) ? 'text-white' : 'text-gray-500'}" }) %>
            <span>게시물 관리</span>
          <% end %>
        </li>
      </ul>
      
      <!-- 스페이서: 사이드바의 나머지 공간을 채워서 버튼을 하단에 배치 -->
      <div class="flex-grow"></div>
      
      <!-- 프론트엔드 페이지로 이동하는 버튼 -->
      <div class="px-2 py-4 mt-2 border-t border-gray-200">
        <%= link_to root_path, 
            class: "flex items-center justify-center px-4 py-3 rounded-lg bg-gradient-to-r from-secondary-30 to-secondary-40 text-white shadow-sm hover:from-secondary-40 hover:to-secondary-50 transition-all duration-300 group" do %>
          <div class="flex items-center">
            <%= heroicon("arrow-uturn-left", options: { class: "w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform duration-300" }) %>
            <span class="font-medium">랜딩 페이지 이동</span>
          </div>
        <% end %>
      </div>
    </aside>
    
    <!-- 가운데 컨텐츠 영역 -->
    <section class="p-10 w-6xl min-w-6xl">
      <%= yield %>
    </section>
    
    <!-- 오른쪽 사이드바 - sticky -->
    <aside class="sticky top-0 flex flex-col h-screen p-6 bg-gray-100 border-l-2 border-gray-300 border-dashed w-96 min-w-96">
      <!-- 시간 표시 -->
      <div class="flex flex-col items-center pt-6 mb-4">
        <div class="text-5xl font-bold text-gray-300" id="current-time">
          <%= Time.now.strftime("%H:%M") %>
        </div>
        <div class="mt-2 text-xl font-medium text-gray-400">
          <%= Time.now.strftime("%Y년 %m월 %d일") %>
        </div>
      </div>
      
      <!-- 시각적 통계 그래프 - 관상용 -->
      <div class="mt-6 mb-8 overflow-hidden bg-white border border-gray-200 shadow-sm rounded-xl">
        <div class="p-4 border-b border-gray-100">
          <h3 class="font-medium text-gray-800">활동 통계</h3>
        </div>
        <div class="p-4">
          <div class="flex items-end h-40 space-x-2">
            <% 7.times do |i| %>
              <% 
                height = rand(30..95)
                day_names = %w(월 화 수 목 금 토 일)
                is_today = i == Time.now.wday - 1 || (Time.now.wday == 0 && i == 6)
                bar_classes = is_today ? "bg-secondary-40" : "bg-gray-300"
              %>
              <div class="flex flex-col items-center flex-1">
                <div style="height: <%= height %>%" class="w-full rounded-t-md <%= bar_classes %> transition-all duration-500 hover:opacity-80"></div>
                <div class="mt-2 text-xs <%= is_today ? 'font-bold text-secondary-60' : 'text-gray-500' %>"><%= day_names[i] %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      
      <!-- 리소스 모니터링 -->
      <div class="mb-8 bg-white border border-gray-200 shadow-sm rounded-xl">
        <div class="p-4 border-b border-gray-100">
          <h3 class="font-medium text-gray-800">시스템 상태</h3>
        </div>
        <div class="p-4">
          <div class="space-y-4">
            <div>
              <div class="flex justify-between mb-1 text-sm">
                <span class="text-gray-600">CPU 사용량</span>
                <span class="font-mono text-gray-800">32%</span>
              </div>
              <div class="w-full h-2 bg-gray-200 rounded-full">
                <div class="h-2 bg-green-500 rounded-full" style="width: 32%"></div>
              </div>
            </div>
            
            <div>
              <div class="flex justify-between mb-1 text-sm">
                <span class="text-gray-600">메모리</span>
                <span class="font-mono text-gray-800">512MB / 1GB</span>
              </div>
              <div class="w-full h-2 bg-gray-200 rounded-full">
                <div class="h-2 bg-blue-500 rounded-full" style="width: 50%"></div>
              </div>
            </div>
            
            <div>
              <div class="flex justify-between mb-1 text-sm">
                <span class="text-gray-600">디스크</span>
                <span class="font-mono text-gray-800">4.7GB / 10GB</span>
              </div>
              <div class="w-full h-2 bg-gray-200 rounded-full">
                <div class="h-2 bg-purple-500 rounded-full" style="width: 47%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- HTTP 상태 코드 표시 -->
      <div class="flex items-center justify-center flex-none mb-4">
        <div class="inline-flex items-center px-3 py-1 bg-green-100 border border-green-200 rounded-full">
          <span class="inline-block w-2 h-2 mr-2 bg-green-500 rounded-full shadow-sm shadow-green-500"></span>
          <span class="font-mono text-sm font-medium text-green-800">200 OK</span>
        </div>
      </div>
      
      <!-- 시스템 정보 -->
      <div class="mt-auto">
        <div class="flex flex-col space-y-2 text-sm text-gray-400">
          <div class="flex justify-between">
            <span>Ruby</span>
            <span class="font-mono"><%= RUBY_VERSION %></span>
          </div>
          <div class="flex justify-between">
            <span>Rails</span>
            <span class="font-mono"><%= Rails.version %></span>
          </div>
          <div class="flex justify-between">
            <span>환경</span>
            <span class="font-mono"><%= Rails.env.upcase %></span>
          </div>
        </div>
      </div>
    </aside>
  </div>
  
  <%= turbo_frame_tag :modal_portal %>
  
  <script>
    function updateClock() {
      const now = new Date();
      const hours = String(now.getHours()).padStart(2, '0');
      const minutes = String(now.getMinutes()).padStart(2, '0');
      const timeDisplay = document.getElementById('current-time');
      if (timeDisplay) {
        timeDisplay.textContent = `${hours}:${minutes}`;
      }
    }
    
    document.addEventListener("turbo:load", function() {
      updateClock();
      setInterval(updateClock, 1000);
    });
    
    if (document.readyState === 'complete') {
      updateClock();
      setInterval(updateClock, 1000);
    }
  </script>
</body>
</html>