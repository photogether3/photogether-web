<!DOCTYPE html>
<html data-theme="cupcake" lang="ko">
  <head>
    <title><%= content_for(:title) || "포토게더 - 관리자" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="http://localhost:5173/app/assets/main.js" type="module"></script>
  </head>

  <body class="flex flex-col">
    <div class="h-14 border-b border-base-300 flex justify-center items-center p-3 gap-2">
      <div class="h-full">
        <img src="/images/photogether-logo.png" class="h-full"/>
      </div>
      <div class="text-xl font-bold">
        포토게더 관리
      </div>
    </div>
    <div class="flex h-[calc(100vh-56px)] overflow-x-auto">
      <aside class="sticky top-0 border-r border-dashed border-base-300 h-full w-[30%] min-w-[300px]
        flex flex-col items-end justify-center p-4">
        <div class="flex flex-col items-center gap-6">
          <ul class="flex flex-col gap-4">
            <li>
              <a
                class="flex flex-col gap-2 text-xs items-center p-2 rounded-md bg-base-200" 
                href="/admin">
                <div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                </div>
                <div>대시보드</div>
              </a>
            </li>
            <li>
              <a
                class="flex flex-col gap-2 text-xs items-center p-2 rounded-md" 
                href="/admin/users">
                <div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                  </svg>
                </div>
                <div>회원관리</div>
              </a>
            </li>
          </ul>
        </div>

      </aside>
      <main class="w-[70%] overflow-y-auto p-4">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
